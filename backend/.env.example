# ==========================================
# RENOVA Circular - Backend Config Example
# Copy this file to .env and fill in values.
# ==========================================

# Database Connection (SQLite locally, or Turso in production)
# Format: libsql://<db-name>-<user>.turso.io
DATABASE_URL=sqlite:///./renova.db

# CORS Allowed Origins (Set to your Netlify public URL in production)
# Format MUST be a JSON array of strings
CORS_ORIGINS=["http://localhost:3000", "https://your-renova-site.netlify.app"]

# Secret key for JWT signatures (Generate a secure random string)
JWT_SECRET_KEY=generate-something-highly-secure-for-production-use-2026

# Symmetric Encryption Key for sensitive database fields
# Generate a new Fernet key in Python:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ULgXQZxIRcrPGGC4gO8he5D8Vor8G08oiWzagVp2948=

# Outbound SMTP Email Configuration
# Set USE_MOCK_EMAIL=False to connect to a real SMTP server
USE_MOCK_EMAIL=True
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-google-app-password
EMAIL_FROM=info@renova.vn
